name: superzet
title: superzet
base: core24
version: "$RELEASE_VERSION"
summary: The terminal shell for coding agents
description: |
  superzet is a native workspace shell for coding agents, built on top of Zed's
  editor, terminal, and diff engine.
grade: stable
confinement: classic
compression: lzo
website: https://github.com/nerdface-ai/superzet
source-code: https://github.com/nerdface-ai/superzet
issues: https://github.com/nerdface-ai/superzet/issues
contact: https://github.com/nerdface-ai/superzet/discussions

parts:
  superzet:
    plugin: dump
    source: "https://github.com/nerdface-ai/superzet/releases/download/v$RELEASE_VERSION/superzet-linux-x86_64.tar.gz"

    organize:
      # These renames seem to not be necessary, but it's tidier.
      bin: usr/bin
      libexec: usr/libexec

    stage-packages:
      - libasound2t64
      # snapcraft has a lint that this is unused, but without it superzet exits with
      # "Missing Vulkan entry points: LibraryLoadFailure" in wgpu.
      - libvulkan1
      # snapcraft has a lint that this is unused, but without it superzet exits with
      # "NoWaylandLib" when run with Wayland.
      - libwayland-client0
      - libxcb1
      - libxkbcommon-x11-0
      - libxkbcommon0

    build-attributes:
      - enable-patchelf

    prime:
      # Omit unneeded files from the tarball
      - -lib
      - -licenses.md
      - -share

      # Omit unneeded files from stage-packages
      - -etc
      - -usr/share/doc
      - -usr/share/lintian
      - -usr/share/man

apps:
  superzet:
    command: usr/bin/superzet
    common-id: ai.nerdface.superzet
    environment:
      ZED_BUNDLE_TYPE: snap
