<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>$APP_ID</id>
    <metadata_license>MIT</metadata_license>
    <project_license>AGPL-3.0-or-later and Apache-2.0 and GPL-3.0-or-later</project_license>

    <name>$APP_NAME</name>
    <summary>Native workspace shell for coding agents</summary>
    <developer id="ai.nerdface.superzet">
        <name translate="no">nerdface-ai</name>
    </developer>
    <description>
        <p>
            superzet combines a workspace shell for coding agents with Zed's native editor, terminal, and diff engine.
        </p>
        <p>Features:</p>
        <ul>
            <li>Projects and workspaces: Manage local repositories and git worktrees from one place.</li>
            <li>Native editor and terminal: Reuse Zed's pane, terminal, and diff workflow in a task-oriented shell.</li>
            <li>Review loop: Keep changes, files, and terminal context visible without leaving the app.</li>
            <li>Local-first: Run your own CLI agents like Codex or Claude Code inside regular terminal tabs.</li>
        </ul>
    </description>

    <launchable type="desktop-id">$APP_ID.desktop</launchable>

    <branding>
        <color type="primary" scheme_preference="light">$BRANDING_LIGHT</color>
        <color type="primary" scheme_preference="dark">$BRANDING_DARK</color>
    </branding>

    <content_rating type="oars-1.1">
        <content_attribute id="social-chat">intense</content_attribute>
        <content_attribute id="social-audio">intense</content_attribute>
    </content_rating>

    <url type="homepage">https://github.com/nerdface-ai/superzet</url>
    <url type="bugtracker">https://github.com/nerdface-ai/superzet/issues</url>
    <url type="help">https://github.com/nerdface-ai/superzet#readme</url>
    <url type="contact">https://github.com/nerdface-ai/superzet/discussions</url>
    <url type="vcs-browser">https://github.com/nerdface-ai/superzet</url>
    <url type="contribute">https://github.com/nerdface-ai/superzet/blob/main/CONTRIBUTING.md</url>

    <supports>
        <internet>offline-only</internet>
    </supports>
    <recommends>
        <control>pointing</control>
        <control>keyboard</control>
        <display_length compare="ge">768</display_length>
    </recommends>

    <screenshots>
        <screenshot type="default">
            <caption>superzet with a repository open and workspace navigation visible</caption>
            <image>https://github.com/nerdface-ai/superzet/raw/main/apps/marketing/public/images/readme-hero.png</image>
        </screenshot>
        <screenshot>
            <caption>superzet with code, terminal tabs, and a details sidebar</caption>
            <image>https://github.com/nerdface-ai/superzet/raw/main/apps/marketing/public/images/readme-hero.png</image>
        </screenshot>
    </screenshots>

    <releases>
		@release_info@
		<release version="0.0.0" date="1970-01-01">
			<description>
				<p>Dummy release to keep flatpak-builder AppStream metadata validation from complaining</p>
			</description>
		</release>
    </releases>
</component>
